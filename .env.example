# ─────────────────────────────────────────────────────────────────────────────
# Whisper server configuration (copy to .env or export in your environment)
#
# Everything is optional — the server runs with sensible dev defaults when
# unset. Client build-time variables live in client/.env.example instead.
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ──────────────────────────────────────────────────────────────────
# TCP port the signaling server listens on.
PORT=8787

# Bind address. Unset = all interfaces. Use 127.0.0.1 when nginx fronts it.
#HOST=127.0.0.1

# ── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of browser Origins allowed to connect (WebSocket + HTTP).
# REQUIRED in production — when unset, any origin is accepted (dev only; the
# server warns at startup).
#ALLOWED_ORIGINS=https://chat.example.com,https://www.example.com

# ── Persistence (optional) ───────────────────────────────────────────────────
# Postgres connection string. When unset the server is fully in-memory:
# no message history, no @handle directory. When set, the server stores
# ciphertext + routing metadata only (never plaintext) and serves history
# on rejoin. sslmode=require is normalized to verify-full (cert-verifying).
#DATABASE_URL=postgres://user:password@localhost:5432/whisper

# ── TURN for reliable calls (optional, recommended for production) ───────────
# Metered.ca API credentials. When set, the server mints short-lived TURN
# credentials per room join — nothing is baked into the client bundle.
#METERED_API_KEY=
#METERED_DOMAIN=yourapp.metered.live

# ── Abuse / DoS limits (defaults shown) ──────────────────────────────────────
# Max concurrent WebSocket connections per client IP.
#MAX_CONNS_PER_IP=30
# Max simultaneous in-memory rooms.
#MAX_ROOMS=10000
# Per-socket message token bucket: burst size and refill rate per second.
#MSG_BURST=180
#MSG_REFILL_PER_SEC=60
# Per-IP requests/minute on the @handle HTTP endpoints.
#HANDLE_RATE_LIMIT=20
